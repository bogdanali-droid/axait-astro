---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}

const { 
  title, 
  description = "AXA IT oferă soluții IT complete, adaptate afacerii tale — mentenanță, rețelistică, cloud, securitate și suport permanent.",
  image = "/og-image-1200x630.png",
  type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://axait.ro");
const ogImage = image.startsWith('http') ? image : `https://axait.ro${image}`;
const fullTitle = title.length > 45 ? title : `${title} | AXA IT`;
---

<!DOCTYPE html>
<html lang="ro" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  
  <!-- Theme color -->
  <meta name="theme-color" content="#0A0A0A">
  <meta name="msapplication-TileColor" content="#FF5A1F">
  
  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="AXA IT" />
  <meta property="og:locale" content="ro_RO" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={canonicalURL} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
  <!-- Geist Sans + Space Grotesk Fonts -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&display=swap">
  <style>
    @font-face {
      font-family: 'Geist';
      src: url('https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/Geist-Regular.woff2') format('woff2');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Geist';
      src: url('https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/Geist-Medium.woff2') format('woff2');
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Geist';
      src: url('https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/Geist-SemiBold.woff2') format('woff2');
      font-weight: 600;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Geist';
      src: url('https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/Geist-Light.woff2') format('woff2');
      font-weight: 300;
      font-style: normal;
      font-display: swap;
    }
  </style>
  
  <!-- LocalBusiness + WebSite Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": "https://axait.ro/#business",
        "name": "AXA IT",
        "url": "https://axait.ro",
        "logo": {
          "@type": "ImageObject",
          "url": "https://axait.ro/img/logo/logo-horizontal-light.svg"
        },
        "image": "https://axait.ro/og-image-1200x630.png",
        "description": "Soluții IT complete pentru firme din București — mentenanță, rețelistică, cloud, securitate și outsourcing IT. 10+ ani experiență, 150+ clienți activi.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Dealul Tugulea 64",
          "addressLocality": "București",
          "addressCountry": "RO"
        },
        "telephone": "+40-727-897-849",
        "email": "office@axa-it.ro",
        "priceRange": "€€",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
            "opens": "08:00",
            "closes": "18:00"
          }
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+40-727-897-849",
          "contactType": "customer service",
          "availableLanguage": "Romanian"
        },
        "areaServed": [
          {"@type": "City", "name": "București"},
          {"@type": "Country", "name": "România"}
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicii IT",
          "itemListElement": [
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Mentenanță IT"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Outsourcing IT"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Cloud & Backup"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Protecție Cibernetică"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Rețelistică & Wi-Fi"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Securitate & Supraveghere"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Virtualizare Servere"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Consultanță & Audit IT"}}
          ]
        },
        "sameAs": [
          "https://www.facebook.com/axait.ro",
          "https://www.instagram.com/axait.ro"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://axait.ro/#website",
        "url": "https://axait.ro",
        "name": "AXA IT",
        "description": "Soluții IT complete pentru firme din București",
        "publisher": {"@id": "https://axait.ro/#business"},
        "inLanguage": "ro-RO"
      }
    ]
  }
  </script>
  
  <slot name="schema" />
</head>
<body class="antialiased bg-brand-light text-brand-dark">
  <slot />

  <!-- WhatsApp Floating Button -->
  <a 
    href="https://wa.me/40727897849?text=Bună%20ziua!%20Aș%20dori%20mai%20multe%20informații%20despre%20serviciile%20AXA%20IT."
    target="_blank"
    rel="noopener"
    aria-label="Contactează-ne pe WhatsApp"
    class="whatsapp-fab group fixed bottom-6 right-6 z-[100] flex items-center"
  >
    <span class="hidden group-hover:flex items-center mr-3 bg-white text-brand-dark text-[14px] font-medium px-4 py-2 rounded-full shadow-lg border border-brand-border/40 whitespace-nowrap transition-all">
      Scrie-ne pe WhatsApp
    </span>
    <span class="relative flex items-center justify-center w-14 h-14 bg-[#25D366] rounded-full shadow-lg shadow-[#25D366]/30 hover:shadow-xl hover:shadow-[#25D366]/40 hover:scale-105 transition-all">
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span class="absolute -top-0.5 -right-0.5 w-3.5 h-3.5 bg-red-500 rounded-full border-2 border-white animate-pulse"></span>
    </span>
  </a>
</body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  html, body {
    font-family: 'Geist', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    overflow-x: hidden;
    width: 100%;
    max-width: 100vw;
  }

  ::selection {
    background: #FF5A1F;
    color: #0A0A0A;
  }

  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
  }

  ::-webkit-scrollbar-thumb {
    background: #FF5A1F;
    border-radius: 4px;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .glass-card-light {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }

  @keyframes pulse-node {
    0%, 100% { r: 7; opacity: 0.8; }
    50% { r: 9; opacity: 1; }
  }

  @keyframes travel {
    0% { offset-distance: 0%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  @keyframes grow-bar {
    0% { transform: scaleY(0); }
    100% { transform: scaleY(1); }
  }

  @keyframes slide-up {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marquee-reverse {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @keyframes fade-in {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .animate-float {
    animation: float 5s ease-in-out infinite;
    contain: layout style;
  }

  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
    contain: layout style;
  }

  .animate-grow-bar {
    animation: grow-bar 1.2s ease-out forwards;
    transform-origin: bottom;
  }

  .animate-marquee {
    animation: marquee 45s linear infinite;
    display: flex;
    width: max-content;
  }

  .animate-marquee-reverse {
    animation: marquee-reverse 40s linear infinite;
    display: flex;
    width: max-content;
  }

  .brand-marquee:hover .animate-marquee,
  .brand-marquee:hover .animate-marquee-reverse {
    animation-play-state: paused;
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-400 { animation-delay: 400ms; }
  .animation-delay-500 { animation-delay: 500ms; }
  .animation-delay-600 { animation-delay: 600ms; }
  .animation-delay-1000 { animation-delay: 1000ms; }
  .animation-delay-2000 { animation-delay: 2000ms; }
  .animation-delay-3000 { animation-delay: 3000ms; }
</style>