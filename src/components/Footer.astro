---
---

<footer class="relative bg-brand-dark overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-brand-accent/5 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-brand-accent/5 rounded-full blur-[120px]"></div>
  </div>
  
  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-12 gap-8 lg:gap-12 pb-12 border-b border-white/5">
      
      <div class="col-span-2 md:col-span-4 lg:col-span-4">
        <a href="/" class="inline-block mb-4">
          <img src="/img/logo/logo-horizontal-dark.svg" alt="AXA IT" class="h-10" width="208" height="40" />
        </a>
        <p class="text-brand-steel text-[11px] uppercase tracking-[4px] mb-4 font-light">Infrastructure · Services · Security</p>
        <p class="text-white/40 text-[15px] leading-relaxed mb-6 max-w-xs">
          Soluții IT complete, adaptate afacerii tale. Mentenanță, rețelistică, cloud, securitate și suport permanent.
        </p>
        
        <div class="flex items-center gap-2">
          <a href="https://www.facebook.com/axait.ro" target="_blank" rel="noopener" aria-label="Facebook AXA IT" class="group w-10 h-10 bg-white/5 hover:bg-brand-accent rounded-xl flex items-center justify-center transition-all">
            <svg class="w-5 h-5 text-white/40 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/axait.ro" target="_blank" rel="noopener" aria-label="Instagram AXA IT" class="group w-10 h-10 bg-white/5 hover:bg-gradient-to-br hover:from-purple-600 hover:to-pink-500 rounded-xl flex items-center justify-center transition-all">
            <svg class="w-5 h-5 text-white/40 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>
      
      <div class="col-span-1 lg:col-span-2">
        <h4 class="text-white font-medium text-[13px] uppercase tracking-wider mb-5">Servicii</h4>
        <ul class="space-y-3">
          <li><a href="/servicii/mentenanta-suport-it" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Mentenanță IT</a></li>
          <li><a href="/servicii/retelistica-wifi" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Rețelistică & Wi-Fi</a></li>
          <li><a href="/servicii/cloud-backup" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Cloud & Backup</a></li>
          <li><a href="/servicii/securitate-supraveghere" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Securitate</a></li>
          <li><a href="/servicii/outsourcing-it" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Outsourcing IT</a></li>
          <li><a href="/servicii/protectie-cibernetica" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Protecție Cibernetică</a></li>
          <li><a href="/servicii/virtualizare-servere" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Virtualizare</a></li>
          <li><a href="/servicii/consultanta-audit" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Consultanță IT</a></li>
        </ul>
      </div>
      
      <div class="col-span-1 lg:col-span-2">
        <h4 class="text-white font-medium text-[13px] uppercase tracking-wider mb-5">Companie</h4>
        <ul class="space-y-3">
          <li><a href="/despre" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Despre noi</a></li>
          <li><a href="/blog" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-white/40 hover:text-brand-accent text-[14px] transition-colors">Contact</a></li>
        </ul>
        
        <h4 class="text-white font-medium text-[13px] uppercase tracking-wider mb-4 mt-8">Parteneri</h4>
        <ul class="space-y-2">
          <li class="text-white/30 text-[13px]">TP-Link</li>
          <li class="text-white/30 text-[13px]">Fortinet</li>
          <li class="text-white/30 text-[13px]">Ubiquiti</li>
          <li class="text-white/30 text-[13px]">Microsoft</li>
        </ul>
      </div>
      
      <div class="col-span-2 md:col-span-2 lg:col-span-4">
        <h4 class="text-white font-medium text-[13px] uppercase tracking-wider mb-5">Contact</h4>
        <div class="space-y-4">
          <div class="p-4 bg-white/5 rounded-xl hover:bg-white/[0.07] transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-6 h-6 bg-brand-accent/20 rounded-lg flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </div>
              <span class="text-white/60 text-[12px] font-medium">București</span>
            </div>
            <p class="text-white/40 text-[13px]">Dealul Tugulea 64</p>
          </div>
          
          <div class="flex flex-wrap gap-4">
            <a href="tel:+40727897849" class="inline-flex items-center gap-2 text-white/40 hover:text-brand-accent text-[14px] transition-colors">
              <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              0727 897 849
            </a>
            <a href="mailto:office@axa-it.ro" class="inline-flex items-center gap-2 text-white/40 hover:text-brand-accent text-[14px] transition-colors">
              <svg class="w-4 h-4 text-brand-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              office@axa-it.ro
            </a>
          </div>
          
          <div class="text-white/30 text-[13px]">
            <p>Lu-Vi: 08:00 – 18:00</p>
            <p>Sa-Du: Închis</p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-white/30 text-[13px]">
        &copy; 2026 AXA IT. Toate drepturile rezervate.
      </p>
      <div class="flex items-center gap-6 text-[13px]">
        <span class="text-white/20">Powered by AXA IT</span>
      </div>
    </div>
  </div>
</footer>
