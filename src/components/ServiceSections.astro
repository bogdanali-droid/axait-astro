---
interface Feature {
  title: string;
  description: string;
  iconPath: string;
}

interface Step {
  title: string;
  description: string;
}

interface Props {
  accent: 'blue' | 'cyan' | 'violet' | 'red' | 'emerald' | 'amber' | 'indigo' | 'teal';
  eyebrow: string;
  title: string;
  heroDescription: string;
  heroIconPath: string;
  heroImage: string;
  features: Feature[];
  steps: Step[];
  featuresHeading?: string;
  processHeading?: string;
}

const {
  accent,
  eyebrow,
  title,
  heroDescription,
  heroIconPath,
  heroImage,
  features,
  steps,
  featuresHeading = 'Ce include serviciul',
  processHeading = 'Cum lucrăm',
} = Astro.props;

const a = {
  blue:    { text: 'text-brand-accent',    bg: 'bg-blue-50',    borderHover: 'hover:border-brand-accent/50', pill: 'bg-blue-50 text-brand-accent',    blob: 'bg-brand-accent/10' },
  cyan:    { text: 'text-cyan-600',      bg: 'bg-cyan-50',    borderHover: 'hover:border-cyan-300',        pill: 'bg-cyan-50 text-cyan-700',      blob: 'bg-cyan-500/10' },
  violet:  { text: 'text-violet-600',    bg: 'bg-violet-50',  borderHover: 'hover:border-violet-300',      pill: 'bg-violet-50 text-violet-700',  blob: 'bg-violet-500/10' },
  red:     { text: 'text-red-600',       bg: 'bg-red-50',     borderHover: 'hover:border-red-300',         pill: 'bg-red-50 text-red-700',        blob: 'bg-red-500/10' },
  emerald: { text: 'text-emerald-600',   bg: 'bg-emerald-50', borderHover: 'hover:border-emerald-300',     pill: 'bg-emerald-50 text-emerald-700',blob: 'bg-emerald-500/10' },
  amber:   { text: 'text-amber-600',     bg: 'bg-amber-50',   borderHover: 'hover:border-amber-300',       pill: 'bg-amber-50 text-amber-700',   blob: 'bg-amber-500/10' },
  indigo:  { text: 'text-indigo-600',    bg: 'bg-indigo-50',  borderHover: 'hover:border-indigo-300',      pill: 'bg-indigo-50 text-indigo-700',  blob: 'bg-indigo-500/10' },
  teal:    { text: 'text-teal-600',      bg: 'bg-teal-50',    borderHover: 'hover:border-teal-300',        pill: 'bg-teal-50 text-teal-700',      blob: 'bg-teal-500/10' },
} as const;

const c = a[accent];
---

<!-- Hero -->
<section class="relative bg-white pt-32 pb-16 overflow-hidden">
  <div class="absolute inset-0 bg-[linear-gradient(rgba(26,35,50,.03)_1px,transparent_1px),linear-gradient(90deg,rgba(26,35,50,.03)_1px,transparent_1px)] bg-[size:48px_48px] pointer-events-none"></div>
  <div class:list={['absolute top-20 right-0 w-[420px] h-[420px] rounded-full blur-3xl opacity-50 pointer-events-none', c.blob]}></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="flex flex-col-reverse lg:flex-row lg:items-center gap-10 lg:gap-16">
      <!-- Text -->
      <div class="lg:w-1/2">
        <div class:list={['inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6', c.pill]}>
          <span class="text-[13px] font-medium">{eyebrow}</span>
        </div>
        <h1 class="text-[32px] md:text-[44px] font-bold text-brand-dark tracking-tight leading-[1.15]">
          {title}
        </h1>
        <p class="mt-5 text-brand-steel text-[17px] md:text-[18px] leading-relaxed">
          {heroDescription}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-brand-accent hover:bg-brand-accent/90 text-white font-semibold text-[15px] px-7 py-3.5 rounded-full transition-all shadow-lg hover:shadow-xl hover:shadow-brand-accent/20"
          >
            Solicită o consultație
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="tel:+40727897849" class="inline-flex items-center justify-center gap-2 border border-brand-border text-brand-steel hover:text-brand-dark hover:border-brand-steel text-[15px] px-7 py-3.5 rounded-full transition-all">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            +40 727 897 849
          </a>
        </div>
      </div>

      <!-- Image -->
      <div class="lg:w-1/2">
        <img
          src={heroImage}
          alt={title}
          class="w-full rounded-2xl shadow-lg object-cover aspect-[4/3]"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-20 md:py-24 bg-brand-light relative">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-[26px] md:text-[36px] font-bold text-brand-dark">{featuresHeading}</h2>
      <p class="mt-3 text-brand-steel text-[16px] max-w-2xl mx-auto">
        Abordare practică, documentată și aliniată la standardele industriei — pentru continuitate operațională.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div
          class:list={[
            'group bg-white rounded-xl p-8 border border-brand-border/40 transition-all duration-300 hover:shadow-xl hover:shadow-brand-accent/5',
            c.borderHover,
          ]}
        >
          <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center mb-5 group-hover:scale-105 transition-transform', c.bg]}>
            <svg class:list={['w-6 h-6', c.text]} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={f.iconPath} />
            </svg>
          </div>
          <h3 class="text-brand-dark font-semibold text-lg mb-2">{f.title}</h3>
          <p class="text-brand-steel text-[15px] leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Process -->
<section class="py-20 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-[26px] md:text-[36px] font-bold text-brand-dark">{processHeading}</h2>
      <p class="mt-3 text-brand-steel text-[16px] max-w-2xl mx-auto">
        Un parcurs clar, de la evaluare la operare — fără surprize și cu raportare transparentă.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-10 md:gap-8">
      {steps.map((step, i) => (
        <div class="relative">
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-brand-border" aria-hidden="true"></div>
          )}
          <div class="w-14 h-14 rounded-2xl bg-brand-accent text-white font-bold text-xl flex items-center justify-center mb-5 shadow-lg shadow-brand-accent/20">
            {i + 1}
          </div>
          <h3 class="text-brand-dark font-semibold text-xl mb-2">{step.title}</h3>
          <p class="text-brand-steel text-[15px] leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-20 md:py-24 bg-brand-dark relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/3 left-1/4 w-[380px] h-[380px] bg-brand-accent/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-1/4 w-[320px] h-[320px] bg-brand-node/10 rounded-full blur-[100px]"></div>
  </div>
  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-[28px] md:text-[38px] font-bold text-white leading-tight mb-4">
      Pregătit să îmbunătățești infrastructura IT?
    </h2>
    <p class="text-white/50 text-[16px] md:text-[17px] mb-10">
      Discutăm despre nevoile tale și îți propunem un plan concret, adaptat bugetului și obiectivelor afacerii.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/contact" class="group inline-flex items-center gap-2 bg-brand-accent hover:bg-brand-accent/90 text-white font-semibold text-[16px] px-8 py-4 rounded-full transition-all shadow-lg hover:shadow-brand-accent/25">
        Solicită o consultație
        <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
      <a href="tel:+40727897849" class="inline-flex items-center gap-2 text-white/60 hover:text-white text-[16px] transition-colors">
        <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
        +40 727 897 849
      </a>
    </div>
  </div>
</section>
