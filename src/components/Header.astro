{isDark && (
  <script is:inline>
    const header = document.getElementById('header');
    if (header && !header.classList.contains('bg-white/90')) {
      const logoImg = header.querySelector('.header-logo');
      window.addEventListener('scroll', () => {
        const mobileBtn = document.getElementById('mobile-menu-btn');
        if (window.scrollY > 80) {
          header.classList.add('bg-white/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-brand-border/40');
          header.querySelectorAll('.header-link').forEach(el => {
            el.classList.add('text-brand-steel', 'hover:text-brand-dark');
            el.classList.remove('text-white/70', 'hover:text-white');
          });
          if (logoImg) logoImg.src = '/img/logo/logo-horizontal-light.svg';
          if (mobileBtn) { mobileBtn.classList.remove('bg-white/10','hover:bg-white/20'); mobileBtn.classList.add('bg-brand-light','hover:bg-brand-border/30'); }
        } else {
          header.classList.remove('bg-white/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-brand-border/40');
          header.querySelectorAll('.header-link').forEach(el => {
            el.classList.remove('text-brand-steel', 'hover:text-brand-dark');
            el.classList.add('text-white/70', 'hover:text-white');
          });
          if (logoImg) logoImg.src = '/img/logo/logo-horizontal-dark.svg';
          if (mobileBtn) { mobileBtn.classList.add('bg-white/10','hover:bg-white/20'); mobileBtn.classList.remove('bg-brand-light','hover:bg-brand-border/30'); }
        }
      });
    }
  </script>
)}

<script is:inline>
  window.__mobileMenuOpen = false;
  
  (function() {
    const header = document.getElementById('header');
    if (!header) return;
    let lastScrollY = 0;
    let ticking = false;
    
    function updateHeader() {
      const currentScrollY = window.scrollY;
      if (window.__mobileMenuOpen) { header.style.transform = 'translateY(0)'; ticking = false; return; }
      if (currentScrollY < 100) { header.style.transform = 'translateY(0)'; ticking = false; lastScrollY = currentScrollY; return; }
      const diff = currentScrollY - lastScrollY;
      if (Math.abs(diff) < 10) { ticking = false; return; }
      header.style.transform = diff > 0 ? 'translateY(-100%)' : 'translateY(0)';
      lastScrollY = currentScrollY;
      ticking = false;
    }
    
    window.addEventListener('scroll', function() {
      if (!ticking) { requestAnimationFrame(updateHeader); ticking = true; }
    }, { passive: true });
  })();
  
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  let isMenuOpen = false;
  
  function toggleMobileMenu() {
    isMenuOpen = !isMenuOpen;
    window.__mobileMenuOpen = isMenuOpen;
    if (isMenuOpen) {
      if (mobileMenu) mobileMenu.classList.remove('hidden');
      if (menuIconOpen) menuIconOpen.classList.add('hidden');
      if (menuIconClose) menuIconClose.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      document.getElementById('header').style.transform = 'translateY(0)';
    } else {
      if (mobileMenu) mobileMenu.classList.add('hidden');
      if (menuIconOpen) menuIconOpen.classList.remove('hidden');
      if (menuIconClose) menuIconClose.classList.add('hidden');
      document.body.style.overflow = '';
    }
  }

  if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', toggleMobileMenu);
  document.querySelectorAll('.mobile-menu-link').forEach(link => {
    link.addEventListener('click', () => { if (isMenuOpen) toggleMobileMenu(); });
  });
  window.addEventListener('resize', () => { if (window.innerWidth >= 768 && isMenuOpen) toggleMobileMenu(); });
</script>
