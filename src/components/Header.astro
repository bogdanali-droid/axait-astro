        ))}
      </div>
      <a href="/despre" class="py-3 text-[18px] text-brand-dark hover:text-brand-accent font-medium transition-colors mobile-menu-link">Despre noi</a>
      <a href="/blog" class="py-3 text-[18px] text-brand-dark hover:text-brand-accent font-medium transition-colors mobile-menu-link">Blog</a>
      <a href="/contact" class="py-3 text-[18px] text-brand-dark hover:text-brand-accent font-medium transition-colors mobile-menu-link">Contact</a>
