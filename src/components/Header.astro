    <div class="mt-auto p-6 border-t border-brand-border/30">
      <a href="/contact" class="mobile-menu-link flex items-center justify-center gap-2 w-full bg-brand-accent hover:bg-brand-accent/90 text-white font-semibold text-[16px] px-6 py-4 rounded-xl transition-all">
