---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Soluții IT complete, adaptate afacerii tale" description="AXA IT oferă mentenanță IT, rețelistică, cloud, securitate și suport permanent. 150+ clienți activi, 10+ ani experiență, suport 24/7.">

  <Header variant="dark" />

  <main>

    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="relative min-h-screen flex items-center bg-brand-dark overflow-hidden">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.015)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.015)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-brand-light to-transparent z-20 pointer-events-none"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 py-32 flex flex-col lg:flex-row items-center gap-16 w-full">

        <!-- Left content -->
        <div class="lg:w-1/2">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-brand-accent/30 bg-brand-accent/5 mb-8">
            <span class="text-brand-accent text-[12px] font-medium tracking-widest uppercase">Infrastructură · Servicii · Securitate</span>
          </div>

          <h1 class="text-[36px] md:text-[48px] lg:text-[56px] font-medium text-white leading-[1.12] tracking-tight">
            Infrastructura ta digitală,<br/>
            <span class="text-brand-accent">grija noastră.</span>
          </h1>

          <p class="mt-6 text-[17px] md:text-[19px] text-white/60 max-w-xl leading-relaxed font-light">
            De peste 10 ani construim, securizăm și întreținem infrastructuri IT pentru companii din România. Mentenanță preventivă, rețelistică avansată și suport non-stop.
          </p>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="group inline-flex items-center justify-center gap-2 bg-brand-blue hover:bg-brand-blue/90 text-white font-medium text-[15px] px-7 py-3.5 rounded-full transition-all hover:shadow-lg hover:shadow-brand-blue/25">
              Solicită o consultație
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/></svg>
            </a>
            <a href="#servicii" class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 text-white/70 hover:text-white font-medium text-[15px] px-7 py-3.5 rounded-full transition-all">
              Descoperă serviciile
            </a>
          </div>

          <div class="mt-12 flex flex-wrap items-center gap-8 text-[13px]">
            <div>
              <span class="text-white font-medium text-[20px]">150+</span>
              <span class="text-white/40 ml-1.5">clienți</span>
            </div>
            <div class="w-px h-5 bg-white/10"></div>
            <div>
              <span class="text-white font-medium text-[20px]">10+</span>
              <span class="text-white/40 ml-1.5">ani experiență</span>
            </div>
            <div class="w-px h-5 bg-white/10"></div>
            <div>
              <span class="text-white font-medium text-[20px]">24/7</span>
              <span class="text-white/40 ml-1.5">suport</span>
            </div>
          </div>
        </div>

        <!-- Right: Animated Network X SVG -->
        <div class="lg:w-1/2 hidden lg:flex items-center justify-center">
          <svg viewBox="0 0 400 400" class="w-full max-w-[440px] h-auto" xmlns="http://www.w3.org/2000/svg">
            <style>
              @keyframes pulse-center {
                0%, 100% { transform: scale(1); }
                50% { transform: scale(1.1); }
              }
              @keyframes pulse-corner {
                0%, 100% { transform: scale(1); opacity: 0.9; }
                50% { transform: scale(1.06); opacity: 1; }
              }
              @keyframes travel-dot-1 {
                0% { offset-distance: 0%; opacity: 0; }
                8% { opacity: 1; }
                92% { opacity: 1; }
                100% { offset-distance: 100%; opacity: 0; }
              }
              @keyframes travel-dot-2 {
                0% { offset-distance: 0%; opacity: 0; }
                8% { opacity: 1; }
                92% { opacity: 1; }
                100% { offset-distance: 100%; opacity: 0; }
              }
              @keyframes fade-node {
                0%, 100% { opacity: 0.15; }
                50% { opacity: 0.5; }
              }
              @keyframes glow-ring {
                0%, 100% { opacity: 0.08; r: 24; }
                50% { opacity: 0.2; r: 30; }
              }
              .center-node {
                transform-origin: 200px 200px;
                animation: pulse-center 3s ease-in-out infinite;
              }
              .corner-tl { transform-origin: 80px 80px; animation: pulse-corner 4s ease-in-out infinite; }
              .corner-tr { transform-origin: 320px 80px; animation: pulse-corner 4s ease-in-out 1s infinite; }
              .corner-bl { transform-origin: 80px 320px; animation: pulse-corner 4s ease-in-out 2s infinite; }
              .corner-br { transform-origin: 320px 320px; animation: pulse-corner 4s ease-in-out 3s infinite; }
              .particle-1 {
                offset-path: path('M 80 80 L 320 320');
                animation: travel-dot-1 3s linear infinite;
              }
              .particle-2 {
                offset-path: path('M 320 80 L 80 320');
                animation: travel-dot-2 3.5s linear 0.5s infinite;
              }
              .particle-3 {
                offset-path: path('M 320 320 L 80 80');
                animation: travel-dot-1 4s linear 1s infinite;
              }
              .particle-4 {
                offset-path: path('M 80 320 L 320 80');
                animation: travel-dot-2 3.2s linear 1.5s infinite;
              }
              .particle-5 {
                offset-path: path('M 80 80 L 200 200');
                animation: travel-dot-1 2.5s linear 0.3s infinite;
              }
              .particle-6 {
                offset-path: path('M 200 200 L 320 80');
                animation: travel-dot-2 2.8s linear 0.7s infinite;
              }
              .whisker-node { animation: fade-node 5s ease-in-out infinite; }
              .whisker-node-2 { animation: fade-node 6s ease-in-out 1.5s infinite; }
              .whisker-node-3 { animation: fade-node 4.5s ease-in-out 3s infinite; }
              .whisker-node-4 { animation: fade-node 5.5s ease-in-out 0.8s infinite; }
              .whisker-node-5 { animation: fade-node 7s ease-in-out 2s infinite; }
              .whisker-node-6 { animation: fade-node 4s ease-in-out 4s infinite; }
              .whisker-node-7 { animation: fade-node 6.5s ease-in-out 2.5s infinite; }
              .whisker-node-8 { animation: fade-node 5s ease-in-out 3.5s infinite; }
              .glow-ring { animation: glow-ring 3s ease-in-out infinite; }
            </style>

            <!-- Subtle glow behind center -->
            <circle cx="200" cy="200" r="60" fill="#3B8FD4" opacity="0.04" />
            <circle cx="200" cy="200" r="100" fill="#3B8FD4" opacity="0.02" />

            <!-- Whisker lines from corners outward -->
            <line x1="80" y1="80" x2="30" y2="30" stroke="#3B8FD4" stroke-width="1" opacity="0.15" />
            <line x1="320" y1="80" x2="370" y2="30" stroke="#3B8FD4" stroke-width="1" opacity="0.15" />
            <line x1="80" y1="320" x2="30" y2="370" stroke="#3B8FD4" stroke-width="1" opacity="0.15" />
            <line x1="320" y1="320" x2="370" y2="370" stroke="#3B8FD4" stroke-width="1" opacity="0.15" />
            <line x1="80" y1="80" x2="40" y2="80" stroke="#3B8FD4" stroke-width="1" opacity="0.1" />
            <line x1="320" y1="80" x2="360" y2="80" stroke="#3B8FD4" stroke-width="1" opacity="0.1" />
            <line x1="80" y1="320" x2="80" y2="360" stroke="#3B8FD4" stroke-width="1" opacity="0.1" />
            <line x1="320" y1="320" x2="320" y2="360" stroke="#3B8FD4" stroke-width="1" opacity="0.1" />
            <line x1="80" y1="80" x2="80" y2="40" stroke="#3B8FD4" stroke-width="1" opacity="0.1" />
            <line x1="320" y1="80" x2="320" y2="40" stroke="#3B8FD4" stroke-width="1" opacity="0.1" />

            <!-- Outer whisker nodes -->
            <circle cx="30" cy="30" r="4" fill="#5BA3DE" class="whisker-node" />
            <circle cx="370" cy="30" r="3.5" fill="#5BA3DE" class="whisker-node-2" />
            <circle cx="30" cy="370" r="3.5" fill="#5BA3DE" class="whisker-node-3" />
            <circle cx="370" cy="370" r="4" fill="#5BA3DE" class="whisker-node-4" />
            <circle cx="40" cy="80" r="3" fill="#5BA3DE" class="whisker-node-5" />
            <circle cx="360" cy="80" r="3" fill="#5BA3DE" class="whisker-node-6" />
            <circle cx="80" cy="40" r="3" fill="#5BA3DE" class="whisker-node-7" />
            <circle cx="320" cy="40" r="2.5" fill="#5BA3DE" class="whisker-node-8" />
            <circle cx="80" cy="360" r="3" fill="#5BA3DE" class="whisker-node" />
            <circle cx="320" cy="360" r="2.5" fill="#5BA3DE" class="whisker-node-3" />

            <!-- Main X diagonal lines -->
            <line x1="80" y1="80" x2="320" y2="320" stroke="#3B8FD4" stroke-width="3" opacity="0.7" stroke-linecap="round" />
            <line x1="320" y1="80" x2="80" y2="320" stroke="#3B8FD4" stroke-width="3" opacity="0.7" stroke-linecap="round" />

            <!-- Secondary connection lines (center to corners, thinner) -->
            <line x1="200" y1="200" x2="80" y2="80" stroke="#3B8FD4" stroke-width="1.5" opacity="0.3" />
            <line x1="200" y1="200" x2="320" y2="80" stroke="#3B8FD4" stroke-width="1.5" opacity="0.3" />
            <line x1="200" y1="200" x2="80" y2="320" stroke="#3B8FD4" stroke-width="1.5" opacity="0.3" />
            <line x1="200" y1="200" x2="320" y2="320" stroke="#3B8FD4" stroke-width="1.5" opacity="0.3" />

            <!-- Traveling particles -->
            <circle r="3" fill="#5BA3DE" class="particle-1" />
            <circle r="3" fill="#5BA3DE" class="particle-2" />
            <circle r="2.5" fill="#3B8FD4" class="particle-3" />
            <circle r="2.5" fill="#3B8FD4" class="particle-4" />
            <circle r="2" fill="#5BA3DE" class="particle-5" />
            <circle r="2" fill="#5BA3DE" class="particle-6" />

            <!-- Center glow ring -->
            <circle cx="200" cy="200" r="24" fill="none" stroke="#3B8FD4" stroke-width="1" class="glow-ring" />

            <!-- 4 Corner nodes -->
            <circle cx="80" cy="80" r="12" fill="#2563A8" class="corner-tl" />
            <circle cx="80" cy="80" r="5" fill="#5BA3DE" opacity="0.6" class="corner-tl" />
            <circle cx="320" cy="80" r="12" fill="#2563A8" class="corner-tr" />
            <circle cx="320" cy="80" r="5" fill="#5BA3DE" opacity="0.6" class="corner-tr" />
            <circle cx="80" cy="320" r="12" fill="#2563A8" class="corner-bl" />
            <circle cx="80" cy="320" r="5" fill="#5BA3DE" opacity="0.6" class="corner-bl" />
            <circle cx="320" cy="320" r="12" fill="#2563A8" class="corner-br" />
            <circle cx="320" cy="320" r="5" fill="#5BA3DE" opacity="0.6" class="corner-br" />

            <!-- Center node (largest) -->
            <circle cx="200" cy="200" r="16" fill="#5BA3DE" class="center-node" />
            <circle cx="200" cy="200" r="7" fill="#F4F6F9" opacity="0.3" class="center-node" />
          </svg>
        </div>
      </div>
    </section>


    <!-- ═══════════════════ PARTNERS BAND ═══════════════════ -->
    <section class="py-10 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <p class="text-center text-brand-steel text-[12px] tracking-widest uppercase font-medium mb-6">Parteneri de încredere</p>
        <div class="flex flex-wrap justify-center items-center gap-x-3 gap-y-3 text-brand-steel font-medium text-[14px]">
          <span>Microsoft</span>
          <span class="text-brand-border">·</span>
          <span>Fortinet</span>
          <span class="text-brand-border">·</span>
          <span>Ubiquiti</span>
          <span class="text-brand-border">·</span>
          <span>TP-Link</span>
          <span class="text-brand-border">·</span>
          <span>Acronis</span>
          <span class="text-brand-border">·</span>
          <span>Bitdefender</span>
        </div>
      </div>
    </section>


    <!-- ═══════════════════ SERVICES GRID ═══════════════════ -->
    <section id="servicii" class="py-24 bg-brand-light">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-brand-blue/10 rounded-full mb-6">
            <svg class="w-4 h-4 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
            <span class="text-brand-blue text-[13px] font-medium">Serviciile noastre</span>
          </div>
          <h2 class="text-[28px] md:text-[42px] font-medium text-brand-dark">
            Servicii IT complete
          </h2>
          <p class="mt-4 text-brand-steel text-[17px] max-w-2xl mx-auto font-light">
            De la mentenanță preventivă la securitate completă — acoperim întreaga infrastructură IT a afacerii tale.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">

          <!-- Mentenanță & Suport IT -->
          <a href="/servicii/mentenanta-suport-it" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
            <img src="/img/servicii/mentenanta-suport-it.jpg" alt="Mentenanță & Suport IT" class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 bg-brand-blue/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>
                </div>
                <h3 class="text-brand-dark font-medium text-[18px] group-hover:text-brand-blue transition-colors">Mentenanță & Suport IT</h3>
              </div>
              <p class="text-brand-steel text-[14px] leading-relaxed mb-4 font-light">Mentenanță preventivă, intervenții rapide și monitorizare permanentă. Sistemele tale funcționează fără întreruperi.</p>
              <span class="text-brand-blue text-[14px] font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Află mai mult <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </div>
          </a>

          <!-- Rețelistică & Wi-Fi -->
          <a href="/servicii/retelistică-wifi" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
            <img src="/img/servicii/retelistică-wifi.jpg" alt="Rețelistică & Wi-Fi" class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 bg-brand-accent/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>
                </div>
                <h3 class="text-brand-dark font-medium text-[18px] group-hover:text-brand-accent transition-colors">Rețelistică & Wi-Fi</h3>
              </div>
              <p class="text-brand-steel text-[14px] leading-relaxed mb-4 font-light">Rețele cablate și wireless performante, adaptate mediului tău — de la birouri la hale logistice și spații industriale.</p>
              <span class="text-brand-accent text-[14px] font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Află mai mult <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </div>
          </a>

          <!-- Cloud & Backup -->
          <a href="/servicii/cloud-backup" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
            <img src="/img/servicii/cloud-backup.jpg" alt="Cloud & Backup" class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 bg-brand-node/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-node" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/></svg>
                </div>
                <h3 class="text-brand-dark font-medium text-[18px] group-hover:text-brand-node transition-colors">Cloud & Backup</h3>
              </div>
              <p class="text-brand-steel text-[14px] leading-relaxed mb-4 font-light">Soluții cloud și backup automatizat cu Acronis. Date securizate, accesibile de oriunde și conforme GDPR.</p>
              <span class="text-brand-node text-[14px] font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Află mai mult <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </div>
          </a>

          <!-- Securitate & Supraveghere -->
          <a href="/servicii/securitate-supraveghere" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
            <img src="/img/servicii/securitate-supraveghere.jpg" alt="Securitate & Supraveghere" class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 bg-red-500/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/></svg>
                </div>
                <h3 class="text-brand-dark font-medium text-[18px] group-hover:text-red-500 transition-colors">Securitate & Supraveghere</h3>
              </div>
              <p class="text-brand-steel text-[14px] leading-relaxed mb-4 font-light">Supraveghere video, control acces, pontaj și automatizări integrate. Securitate fizică și digitală într-un singur pachet.</p>
              <span class="text-red-500 text-[14px] font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Află mai mult <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </div>
          </a>

          <!-- Outsourcing IT -->
          <a href="/servicii/outsourcing-it" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
            <img src="/img/servicii/outsourcing-it.jpg" alt="Outsourcing IT" class="w-full h-48 object-cover" loading="lazy" />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 bg-emerald-500/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
                </div>
                <h3 class="text-brand-dark font-medium text-[18px] group-hover:text-emerald-500 transition-colors">Outsourcing IT</h3>
              </div>
              <p class="text-brand-steel text-[14px] leading-relaxed mb-4 font-light">Departament IT complet externalizat, fără costurile angajării interne. Suport permanent și monitorizare 24/7.</p>
              <span class="text-emerald-500 text-[14px] font-medium inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Află mai mult <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </span>
            </div>
          </a>

          <!-- Protecție Cibernetică -->
          <a href="/servicii/protectie-cibernetica" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
