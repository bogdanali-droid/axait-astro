---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Soluții IT complete, adaptate afacerii tale" description="AXA IT oferă mentenanță IT, rețelistică, cloud, securitate și suport permanent. 150+ sisteme monitorizate, 10 ani experiență, 7 industrii.">

  <Header variant="dark" />

  <main>
    <!-- HERO -->
    <section class="relative min-h-screen flex items-center bg-slate-900 overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute top-1/4 left-1/4 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[150px] animate-pulse-slow"></div>
        <div class="absolute bottom-1/3 right-1/4 w-[400px] h-[400px] bg-cyan-500/10 rounded-full blur-[120px] animate-pulse-slow animation-delay-2000"></div>
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.02)_1px,transparent_1px)] bg-[size:50px_50px]"></div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-6 py-32 grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-blue-400 font-medium text-[14px] tracking-wide mb-6">
            SOLUȚII IT COMPLETE PENTRU AFACEREA TA
          </p>
          
          <h1 class="text-[36px] md:text-[48px] lg:text-[56px] font-semibold text-white leading-[1.15] tracking-tight">
            Facem tehnologia<br/>
            <span class="text-white/40">să lucreze pentru tine</span>
          </h1>
          
          <p class="mt-6 text-[18px] md:text-[20px] text-white/60 max-w-xl leading-relaxed">
            De peste <strong class="text-white">10 ani</strong> oferim companiilor din România infrastructură IT stabilă, sigură și scalabilă. Fără întreruperi, fără griji.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-8 text-white/40 text-[14px]">
            <div class="flex items-center gap-2">
              <span class="text-blue-400 font-semibold text-[20px]">150+</span>
              <span>sisteme monitorizate</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-blue-400 font-semibold text-[20px]">10</span>
              <span>ani experiență</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-blue-400 font-semibold text-[20px]">7</span>
              <span>industrii diferite</span>
            </div>
          </div>

          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="group inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-[16px] px-8 py-4 rounded-full transition-all hover:shadow-lg hover:shadow-blue-500/25">
              Solicită o consultație
              <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/></svg>
            </a>
            <a href="tel:+40727897849" class="inline-flex items-center justify-center gap-2 text-white/60 hover:text-white text-[14px] transition-colors">
              <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              +40 727 897 849
            </a>
          </div>
        </div>

        <!-- Glass Dashboard -->
        <div class="relative hidden lg:block">
          <div class="absolute -top-6 -left-6 glass-card px-4 py-3 rounded-xl animate-float z-20">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="text-white/50 text-[10px]">STATUS</p>
                <p class="text-green-400 font-semibold text-[14px]">All systems OK</p>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-4 left-8 glass-card px-4 py-3 rounded-xl animate-float animation-delay-1000 z-20">
            <div class="flex items-center gap-2">
              <span class="text-blue-400 text-[18px]">↑</span>
              <div>
                <p class="text-blue-400 font-semibold text-[14px]">99.9%</p>
                <p class="text-white/40 text-[10px]">uptime</p>
              </div>
            </div>
          </div>

          <div class="absolute top-1/2 -right-4 glass-card px-4 py-3 rounded-xl animate-float animation-delay-2000 z-20">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 bg-white/10 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              </div>
              <p class="text-white text-[13px]">Securizat</p>
            </div>
          </div>

          <div class="glass-card rounded-2xl overflow-hidden">
            <div class="bg-white/5 px-4 py-3 flex items-center gap-2 border-b border-white/5">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-white/20"></div>
                <div class="w-3 h-3 rounded-full bg-white/20"></div>
                <div class="w-3 h-3 rounded-full bg-white/20"></div>
              </div>
              <div class="flex-1 mx-3 bg-white/5 rounded px-3 py-1 text-[11px] text-white/30">it-dashboard.axait.ro</div>
            </div>
            <div class="p-5">
              <div class="grid grid-cols-3 gap-3 mb-5">
                <div class="bg-white/5 rounded-xl p-4">
                  <p class="text-white/40 text-[10px] mb-1">SERVERE</p>
                  <p class="text-white font-semibold text-[18px]">42</p>
                  <p class="text-green-400 text-[11px]">online</p>
                </div>
                <div class="bg-white/5 rounded-xl p-4">
                  <p class="text-white/40 text-[10px] mb-1">TICHETE</p>
                  <p class="text-white font-semibold text-[18px]">3</p>
                  <p class="text-blue-400 text-[11px]">deschise</p>
                </div>
                <div class="bg-white/5 rounded-xl p-4">
                  <p class="text-white/40 text-[10px] mb-1">UPTIME</p>
                  <p class="text-green-400 font-semibold text-[18px]">99.9%</p>
                  <p class="text-green-400 text-[11px]">30 zile</p>
                </div>
              </div>
              <div class="bg-white/5 rounded-xl p-4">
                <p class="text-white/50 text-[11px] mb-3">NETWORK TRAFFIC</p>
                <div class="flex items-end gap-2 h-24">
                  <div class="flex-1 bg-blue-500/60 rounded-t animate-grow-bar" style="height: 40%"></div>
                  <div class="flex-1 bg-blue-500/60 rounded-t animate-grow-bar animation-delay-100" style="height: 55%"></div>
                  <div class="flex-1 bg-blue-500/60 rounded-t animate-grow-bar animation-delay-200" style="height: 45%"></div>
                  <div class="flex-1 bg-blue-500/60 rounded-t animate-grow-bar animation-delay-300" style="height: 70%"></div>
                  <div class="flex-1 bg-blue-500/60 rounded-t animate-grow-bar animation-delay-400" style="height: 85%"></div>
                  <div class="flex-1 bg-blue-500/60 rounded-t animate-grow-bar animation-delay-500" style="height: 65%"></div>
                  <div class="flex-1 bg-blue-500 rounded-t animate-grow-bar animation-delay-600" style="height: 100%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-5 h-5 text-white/30" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
      </div>
    </section>

    <!-- CLIENT LOGOS -->
    <section class="py-14 bg-white relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-8">
          <p class="text-gray-400 text-[12px] tracking-widest uppercase font-medium">Au avut încredere în noi</p>
        </div>
        <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 opacity-50">
          <span class="text-gray-400 font-semibold text-[14px]">ArcelorMittal</span>
          <span class="text-gray-400 font-semibold text-[14px]">Agrinatura Group</span>
          <span class="text-gray-400 font-semibold text-[14px]">Ara Grup</span>
          <span class="text-gray-400 font-semibold text-[14px]">As Construct</span>
          <span class="text-gray-400 font-semibold text-[14px]">Consal Edilitare</span>
          <span class="text-gray-400 font-semibold text-[14px]">Mobila Cara</span>
          <span class="text-gray-400 font-semibold text-[14px]">Wood Class Design</span>
          <span class="text-gray-400 font-semibold text-[14px]">Terra Logistic</span>
          <span class="text-gray-400 font-semibold text-[14px]">Glass Expert</span>
          <span class="text-gray-400 font-semibold text-[14px]">Gaudi Decor</span>
          <span class="text-gray-400 font-semibold text-[14px]">Ideal Profile</span>
          <span class="text-gray-400 font-semibold text-[14px]">Academia de Rugby</span>
          <span class="text-gray-400 font-semibold text-[14px]">Midar Grup</span>
          <span class="text-gray-400 font-semibold text-[14px]">Spot Vision</span>
          <span class="text-gray-400 font-semibold text-[14px]">Next RMA</span>
        </div>
      </div>
    </section>

    <!-- SERVICII -->
    <section id="servicii" class="py-24 bg-slate-50 relative">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 rounded-full mb-6">
            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
            <span class="text-blue-700 text-[13px] font-medium">Serviciile noastre</span>
          </div>
          <h2 class="text-[28px] md:text-[42px] font-bold text-slate-900">
            Soluții integrate pentru fiecare nevoie
          </h2>
          <p class="mt-4 text-slate-500 text-[17px] max-w-2xl mx-auto">
            De la mentenanță preventivă la securitate completă — acoperim întreaga infrastructură IT a afacerii tale.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Mentenanta -->
          <a href="/servicii/mentenanta-suport-it" class="group bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-100/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>
              </div>
              <span class="text-blue-600 text-[12px] font-medium bg-blue-50 px-3 py-1 rounded-full">Suport IT</span>
            </div>
            <h3 class="text-slate-900 font-semibold text-[22px] mb-3 group-hover:text-blue-600 transition-colors">Mentenanță & Suport IT</h3>
            <p class="text-slate-500 text-[15px] leading-relaxed mb-6">Mentenanță preventivă, intervenții rapide și monitorizare permanentă. Sistemele tale funcționează fără întreruperi.</p>
            <div class="flex items-center gap-2 text-blue-600 text-[14px] font-medium">
              <span>Vezi detalii</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </a>
          
          <!-- Retelistică -->
          <a href="/servicii/retelistică-wifi" class="group bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-cyan-300 hover:shadow-xl hover:shadow-cyan-100/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-cyan-50 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-cyan-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>
              </div>
              <span class="text-cyan-600 text-[12px] font-medium bg-cyan-50 px-3 py-1 rounded-full">Networking</span>
            </div>
            <h3 class="text-slate-900 font-semibold text-[22px] mb-3 group-hover:text-cyan-600 transition-colors">Rețelistică & Wi-Fi Industrial</h3>
            <p class="text-slate-500 text-[15px] leading-relaxed mb-6">Rețele cablate și wireless performante, adaptate mediului tău — de la birouri la hale logistice și spații industriale.</p>
            <div class="flex items-center gap-2 text-cyan-600 text-[14px] font-medium">
              <span>Vezi detalii</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </a>
          
          <!-- Cloud -->
          <a href="/servicii/cloud-backup" class="group bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-violet-300 hover:shadow-xl hover:shadow-violet-100/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-violet-50 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-violet-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/></svg>
              </div>
              <span class="text-violet-600 text-[12px] font-medium bg-violet-50 px-3 py-1 rounded-full">Cloud</span>
            </div>
            <h3 class="text-slate-900 font-semibold text-[22px] mb-3 group-hover:text-violet-600 transition-colors">Cloud & Backup</h3>
            <p class="text-slate-500 text-[15px] leading-relaxed mb-6">Soluții cloud și backup automatizat. Infrastructuri sigure, accesibile de oriunde și conforme GDPR.</p>
            <div class="flex items-center gap-2 text-violet-600 text-[14px] font-medium">
              <span>Vezi detalii</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </a>
          
          <!-- Securitate -->
          <a href="/servicii/securitate-supraveghere" class="group bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-red-300 hover:shadow-xl hover:shadow-red-100/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-red-50 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              </div>
              <span class="text-red-600 text-[12px] font-medium bg-red-50 px-3 py-1 rounded-full">Securitate</span>
            </div>
            <h3 class="text-slate-900 font-semibold text-[22px] mb-3 group-hover:text-red-600 transition-colors">Securitate & Supraveghere</h3>
            <p class="text-slate-500 text-[15px] leading-relaxed mb-6">Supraveghere video, control acces, pontaj și automatizări. Sisteme integrate prin parteneri ARTS.</p>
            <div class="flex items-center gap-2 text-red-600 text-[14px] font-medium">
              <span>Vezi detalii</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </a>
          
          <!-- Outsourcing -->
          <a href="/servicii/outsourcing-it" class="group bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-emerald-300 hover:shadow-xl hover:shadow-emerald-100/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-emerald-50 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
              </div>
              <span class="text-emerald-600 text-[12px] font-medium bg-emerald-50 px-3 py-1 rounded-full">Outsourcing</span>
            </div>
            <h3 class="text-slate-900 font-semibold text-[22px] mb-3 group-hover:text-emerald-600 transition-colors">Outsourcing IT</h3>
            <p class="text-slate-500 text-[15px] leading-relaxed mb-6">Departament IT complet, fără costurile angajării interne. Suport permanent, monitorizare 24/7.</p>
            <div class="flex items-center gap-2 text-emerald-600 text-[14px] font-medium">
              <span>Vezi detalii</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </a>
          
          <!-- Protectie Cibernetica -->
          <a href="/servicii/protectie-cibernetica" class="group bg-white rounded-2xl p-8 border border-gray-200/60 hover:border-amber-300 hover:shadow-xl hover:shadow-amber-100/50 transition-all duration-300">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 bg-amber-50 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
              </div>
              <span class="text-amber-600 text-[12px] font-medium bg-amber-50 px-3 py-1 rounded-full">Cyber</span>
            </div>
            <h3 class="text-slate-900 font-semibold text-[22px] mb-3 group-hover:text-amber-600 transition-colors">Protecție Cibernetică</h3>
            <p class="text-slate-500 text-[15px] leading-relaxed mb-6">Firewall-uri, politici de acces, monitorizare rețea și antivirus centralizat. Conformitate GDPR.</p>
