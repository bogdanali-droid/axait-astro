---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  { slug: "de-ce-mentenanta-preventiva-it", title: "De ce mentenanța preventivă IT economisește bani pe termen lung", desc: "Afla cum un plan de mentenanță previne blocajele costisitoare și protejează investițiile tale IT.", date: "2026-04-01", category: "Mentenanță", readTime: "5", image: "/img/blog/mentenanta.svg" },
  { slug: "ghid-securitate-cibernetica-imm", title: "Ghid complet de securitate cibernetică pentru IMM-uri", desc: "Cele mai importante măsuri de protecție pe care orice firmă mică trebuie să le implementeze în 2026.", date: "2026-03-25", category: "Securitate", readTime: "7", image: "/img/blog/securitate.svg" },
  { slug: "cloud-vs-server-local", title: "Cloud vs. Server Local: Ce alegi pentru afacerea ta?", desc: "Comparație detaliată între infrastructura cloud și serverele on-premise. Avantaje, dezavantaje și costuri reale.", date: "2026-03-18", category: "Cloud", readTime: "6", image: "/img/blog/cloud.svg" },
  { slug: "backup-3-2-1-regula-de-aur", title: "Regula 3-2-1: Strategia de backup care îți salvează afacerea", desc: "Cum să implementezi corect o strategie de backup care te protejează de ransomware, erori umane și dezastre.", date: "2026-03-10", category: "Backup", readTime: "5", image: "/img/blog/backup.svg" },
  { slug: "retea-wifi-enterprise-ghid", title: "Cum să proiectezi o rețea Wi-Fi enterprise stabilă și rapidă", desc: "De la site survey la configurare — pașii esențiali pentru un Wi-Fi profesional fără zone moarte.", date: "2026-03-03", category: "Rețelistică", readTime: "8", image: "/img/blog/wifi.svg" },
  { slug: "virtualizare-servere-avantaje", title: "5 avantaje ale virtualizării serverelor pentru companii", desc: "Cum VMware, Hyper-V și Proxmox pot reduce costurile hardware cu până la 60% și cresc flexibilitatea.", date: "2026-02-24", category: "Virtualizare", readTime: "5", image: "/img/blog/virtualizare.svg" },
  { slug: "outsourcing-it-vs-echipa-interna", title: "Outsourcing IT vs. Echipă internă: Ce merită mai mult?", desc: "Analiza cost-beneficiu între a avea un departament IT propriu și externalizarea completă a serviciilor.", date: "2026-02-17", category: "Outsourcing", readTime: "6", image: "/img/blog/outsourcing.svg" },
  { slug: "phishing-cum-te-protejezi", title: "Phishing în 2026: Cum îți protejezi angajații de atacuri", desc: "Cele mai noi tehnici de phishing și cum să antrenezi echipa să recunoască emailurile frauduloase.", date: "2026-02-10", category: "Securitate", readTime: "6", image: "/img/blog/phishing.svg" },
  { slug: "supraveghere-video-ip-ghid", title: "Ghid complet: Sisteme de supraveghere video IP pentru firme", desc: "Cum alegi camerele, NVR-ul și configurația ideală pentru securitatea fizică a sediului tău.", date: "2026-02-03", category: "Supraveghere", readTime: "7", image: "/img/blog/supraveghere.svg" },
  { slug: "audit-it-de-ce-ai-nevoie", title: "Audit IT: De ce ai nevoie de o evaluare a infrastructurii tale", desc: "Ce presupune un audit IT complet, ce riscuri identifică și cum te ajută să iei decizii informate.", date: "2026-01-27", category: "Consultanță", readTime: "5", image: "/img/blog/audit.svg" },
];
---

<Layout title="Blog — Articole și ghiduri IT" description="Articole practice despre mentenanță IT, securitate cibernetică, cloud, rețelistică și soluții IT pentru afaceri. Publicat de echipa AXA IT.">
  <Header />

  <main class="pt-20">
    <section class="py-16 md:py-24 bg-brand-dark">
      <div class="max-w-6xl mx-auto px-6">
        <h1 class="text-[32px] md:text-[48px] font-medium text-white leading-tight">
          Blog <span class="text-brand-accent">AXA IT</span>
        </h1>
        <p class="mt-4 text-white/50 text-[17px] font-light max-w-2xl">
          Articole practice, ghiduri tehnice și sfaturi despre infrastructura IT, securitate cibernetică și soluții cloud pentru afacerea ta.
        </p>
      </div>
    </section>

    <section class="py-16 bg-brand-light">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class:list={[
              "group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-brand-border/30",
              i === 0 && "md:col-span-2 lg:col-span-2"
            ]}>
              <div class="overflow-hidden">
                <img src={post.image} alt={post.title} class:list={[
                  "w-full object-cover group-hover:scale-105 transition-transform duration-500",
                  i === 0 ? "h-[280px]" : "h-[200px]"
                ]} />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="bg-brand-blue/10 text-brand-blue text-[11px] font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider">{post.category}</span>
                  <span class="text-brand-steel text-[12px]">{post.readTime} min</span>
                </div>
                <h2 class:list={[
                  "font-medium text-brand-dark group-hover:text-brand-blue transition-colors leading-snug",
                  i === 0 ? "text-[22px]" : "text-[17px]"
                ]}>{post.title}</h2>
                <p class="mt-2 text-brand-steel text-[14px] font-light leading-relaxed line-clamp-2">{post.desc}</p>
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-brand-steel text-[12px]">{new Date(post.date).toLocaleDateString('ro-RO', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                  <span class="text-brand-blue text-[13px] font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                    Citește
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-[24px] font-medium text-brand-dark mb-4">Ai nevoie de ajutor cu infrastructura IT?</h2>
        <p class="text-brand-steel text-[16px] font-light mb-8">Echipa AXA IT te poate ajuta cu orice provocare tehnologica. Solicita o consultatie gratuita.</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-brand-blue hover:bg-brand-blue/90 text-white font-medium text-[15px] px-7 py-3.5 rounded-full transition-all shadow-sm shadow-brand-blue/20">
          Solicita o consultatie
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/></svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
