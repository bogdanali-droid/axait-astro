---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact"
  description="Contactează AXA IT — telefon, email, adresă în București. Solicită o consultație sau trimite-ne un mesaj."
>
  <Header variant="light" currentPage="/contact" />

  <main class="bg-brand-light min-h-screen">
    <!-- Hero -->
    <section class="relative pt-28 pb-16 md:pb-20 bg-gradient-to-b from-white to-brand-light overflow-hidden">
      <div class="absolute top-20 right-0 w-[400px] h-[400px] bg-blue-500/5 rounded-full blur-[100px] pointer-events-none" />
      <div class="relative max-w-6xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-blue/10 rounded-full mb-6">
          <svg class="w-4 h-4 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
          </svg>
          <span class="text-brand-blue text-[13px] font-medium">Suntem aici pentru tine</span>
        </div>
        <h1 class="text-[32px] md:text-[44px] font-bold text-brand-dark tracking-tight">Contact</h1>
        <p class="mt-4 text-brand-steel text-[17px] md:text-[18px] max-w-2xl mx-auto leading-relaxed">
          Ai nevoie de o consultație sau de suport IT? Sună-ne, scrie-ne sau completează formularul — îți răspundem prompt.
        </p>
      </div>
    </section>

    <!-- Contact cards + form -->
    <section class="pb-20 md:pb-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-12 md:mb-16">
          <a
            href="tel:+40727897849"
            class="group bg-white rounded-2xl p-6 border border-brand-border/60 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-100/40 transition-all duration-300"
          >
            <div class="w-12 h-12 bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <p class="text-[12px] font-semibold uppercase tracking-wider text-brand-blue mb-1">Telefon</p>
            <p class="text-brand-dark font-semibold text-[17px] group-hover:text-brand-blue transition-colors">+40 727 897 849</p>
            <p class="text-slate-400 text-[13px] mt-2">Luni–Vineri, 08:00–18:00</p>
          </a>

          <a
            href="mailto:office@axa-it.ro"
            class="group bg-white rounded-2xl p-6 border border-brand-border/60 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-100/40 transition-all duration-300"
          >
            <div class="w-12 h-12 bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <p class="text-[12px] font-semibold uppercase tracking-wider text-brand-blue mb-1">Email</p>
            <p class="text-brand-dark font-semibold text-[17px] group-hover:text-brand-blue transition-colors break-all">office@axa-it.ro</p>
            <p class="text-slate-400 text-[13px] mt-2">Răspuns în cel mai scurt timp</p>
          </a>

          <div class="bg-white rounded-2xl p-6 border border-brand-border/60 hover:border-blue-200 hover:shadow-lg hover:shadow-blue-100/30 transition-all duration-300">
            <div class="w-12 h-12 bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <p class="text-[12px] font-semibold uppercase tracking-wider text-brand-blue mb-1">Adresă</p>
            <p class="text-brand-dark font-semibold text-[17px] leading-snug">Dealul Tugulea 64</p>
            <p class="text-brand-steel text-[15px] mt-1">București, România</p>
          </div>

          <div class="bg-white rounded-2xl p-6 border border-brand-border/60 hover:border-blue-200 hover:shadow-lg hover:shadow-blue-100/30 transition-all duration-300">
            <div class="w-12 h-12 bg-brand-blue/10 rounded-2xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <p class="text-[12px] font-semibold uppercase tracking-wider text-brand-blue mb-1">Program</p>
            <p class="text-brand-dark font-semibold text-[17px]">Lu–Vi 08:00–18:00</p>
            <p class="text-slate-400 text-[13px] mt-2">Sâmbătă–Duminică: închis</p>
          </div>
        </div>

        <div class="grid lg:grid-cols-5 gap-10 lg:gap-12 items-start">
          <div class="lg:col-span-2 space-y-4">
            <h2 class="text-[22px] md:text-[26px] font-bold text-brand-dark">Solicită o consultație</h2>
            <p class="text-brand-steel text-[15px] leading-relaxed">
              AXA IT oferă <strong class="text-brand-dark">soluții IT complete</strong> — mentenanță, rețelistică, cloud, securitate și suport. Spune-ne cum te putem ajuta.
            </p>
            <ul class="space-y-3 pt-2">
              <li class="flex items-center gap-3 text-slate-600 text-[14px]">
                <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-brand-blue/15 text-brand-blue flex items-center justify-center text-[12px] font-bold">✓</span>
                Peste 10 ani experiență, 150+ sisteme, 7 industrii
              </li>
              <li class="flex items-center gap-3 text-slate-600 text-[14px]">
                <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-brand-blue/15 text-brand-blue flex items-center justify-center text-[12px] font-bold">✓</span>
                Parteneri: TP-Link, Fortinet, Ubiquiti, Microsoft
              </li>
            </ul>
          </div>

          <div class="lg:col-span-3">
            <form
              class="bg-white rounded-2xl p-8 md:p-10 border border-brand-border/60 shadow-sm shadow-slate-200/50"
              onsubmit="event.preventDefault();"
            >
              <div class="grid sm:grid-cols-2 gap-5">
                <div class="sm:col-span-2">
                  <label for="name" class="block text-[13px] font-medium text-brand-dark mb-2">Nume complet</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="name"
                    class="w-full px-4 py-3 rounded-xl border border-brand-border text-brand-dark placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue transition-shadow"
                    placeholder="Ion Popescu"
                  />
                </div>
                <div>
                  <label for="email" class="block text-[13px] font-medium text-brand-dark mb-2">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    class="w-full px-4 py-3 rounded-xl border border-brand-border text-brand-dark placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue transition-shadow"
                    placeholder="you@companie.ro"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-[13px] font-medium text-brand-dark mb-2">Telefon</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    autocomplete="tel"
                    class="w-full px-4 py-3 rounded-xl border border-brand-border text-brand-dark placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue transition-shadow"
                    placeholder="+40 7xx xxx xxx"
                  />
                </div>
                <div class="sm:col-span-2">
                  <label for="company" class="block text-[13px] font-medium text-brand-dark mb-2">Companie</label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    autocomplete="organization"
                    class="w-full px-4 py-3 rounded-xl border border-brand-border text-brand-dark placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue transition-shadow"
                    placeholder="Numele companiei"
                  />
                </div>
                <div class="sm:col-span-2">
                  <label for="message" class="block text-[13px] font-medium text-brand-dark mb-2">Mesaj</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    required
                    class="w-full px-4 py-3 rounded-xl border border-brand-border text-brand-dark placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-blue/30 focus:border-brand-blue transition-shadow resize-y min-h-[120px]"
                    placeholder="Descrie pe scurt nevoia ta sau proiectul..."
                  ></textarea>
                </div>
              </div>
              <div class="mt-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <p class="text-slate-400 text-[13px]">Trimiterea formularului va fi conectată la backend în curând.</p>
                <button
                  type="submit"
                  class="inline-flex items-center justify-center gap-2 bg-brand-blue hover:bg-brand-blue/90 text-white font-semibold text-[15px] px-8 py-3.5 rounded-full transition-all hover:shadow-lg hover:shadow-blue-500/25"
                >
                  Trimite mesajul
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                  </svg>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
