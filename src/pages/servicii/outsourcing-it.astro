---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceSections from '../../components/ServiceSections.astro';

const description =
  'Departament IT externalizat complet: monitorizare 24/7, planificare strategică, suport utilizatori — fără costurile angajării interne.';
---

<Layout title="Outsourcing IT" description={description}>
  <Header variant="light" currentPage="/servicii/outsourcing-it" />
  <main>
    <ServiceSections
      accent="emerald"
      eyebrow="Servicii AXA IT"
      title="Outsourcing IT"
      heroImage="/img/servicii/outsourcing-it.jpg"
      heroDescription="Îți asumăm rolul de departament IT: de la helpdesk și administrare servere până la proiecte și relația cu furnizorii. Primești echipe multidisciplinare, instrumente de monitorizare și raportare periodică — plătești un model predictibil, nu salarii + recrutare + training."
      heroIconPath="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
      features={[
        {
          title: 'Departament IT complet externalizat',
          description:
            'Un singur contract acoperă infrastructură, stații de lucru, colaborare și securitate de bază — cu owner tehnic dedicat.',
          iconPath:
            'M20.25 14.15v4.25c0 .414-.336.75-.75.75h-4.5a.75.75 0 01-.75-.75v-4.25m0-4.25V5.735c0-.414.336-.75.75-.75h4.5c.414 0 .75.336.75.75v4.165m-9.75 0V18.5c0 .414-.336.75-.75.75h-4.5a.75.75 0 01-.75-.75V14.15m0-4.25V5.735c0-.414.336-.75.75-.75h4.5c.414 0 .75.336.75.75v4.165',
        },
        {
          title: 'Monitorizare 24/7',
          description:
            'Alerting pentru servicii critice, discuri și conectivitate — intervenție în afara orelor de program când e nevoie.',
          iconPath:
            'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z',
        },
        {
          title: 'Planificare strategică',
          description:
            'Roadmap IT aliniat obiectivelor de business: înlocuiri, licențe, securitate și bugete pe 12–24 luni.',
          iconPath:
            'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6',
        },
        {
          title: 'Suport permanent',
          description:
            'Canale multiple pentru utilizatori, SLA transparente și escaladare clară către specialiști (rețea, securitate, cloud).',
          iconPath:
            'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
        },
        {
          title: 'Fără costuri de angajare internă',
          description:
            'Elimini recrutarea, concediile, training-ul și rotația personalului — scalăm echipa noastră în funcție de volumul tău.',
          iconPath:
            'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
        },
      ]}
      steps={[
        {
          title: 'Analiză & tranziție',
          description:
            'Audit rapid al infrastructurii, preluare documentație și plan de handover de la echipa internă sau vechiul furnizor.',
        },
        {
          title: 'Implementare servicii',
          description:
            'Activăm monitorizarea, ticketingul și canalele de suport. Stabilim întâlniri regulate cu managementul tău.',
        },
        {
          title: 'Optimizare continuă',
          description:
            'Raportăm KPI-uri, propunem îmbunătățiri și gestionăm proiectele adiacente — IT-ul evoluează odată cu afacerea.',
        },
      ]}
    />
  </main>
  <Footer />
</Layout>
