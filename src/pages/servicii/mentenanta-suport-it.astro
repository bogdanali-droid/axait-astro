---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceSections from '../../components/ServiceSections.astro';

const description =
  'Mentenanță preventivă, suport IT la distanță și la fața locului, ticketing și monitorizare continuă pentru infrastructura ta.';
---

<Layout title="Mentenanță & Suport IT" description={description}>
  <Header variant="light" currentPage="/servicii/mentenanta-suport-it" />
  <main>
    <ServiceSections
      accent="blue"
      eyebrow="Servicii AXA IT"
      title="Mentenanță & Suport IT"
      heroDescription="Reducem downtime-ul prin mentenanță planificată, monitorizare proactivă și echipe care răspund rapid — remote sau la sediul tău. Workflow clar prin ticketing, SLA negociate și rapoarte periodice despre starea sistemelor."
      heroIconPath="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"
      features={[
        {
          title: 'Mentenanță preventivă',
          description:
            'Revizii programate, update-uri de securitate și verificări de sănătate pentru stații, servere și periferice — înainte să devină incidente.',
          iconPath:
            'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
        },
        {
          title: 'Intervenții rapide',
          description:
            'Prioritizăm tichetele critice, comunicăm ETA clar și alocăm tehnicieni potriviți pentru rezolvare în timp util.',
          iconPath: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
        },
        {
          title: 'Monitorizare permanentă',
          description:
            'Alerting pentru discuri, servicii critice, backup și conectivitate — cu dashboard și istoric pentru audit.',
          iconPath:
            'M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
        },
        {
          title: 'Ticketing & trasabilitate',
          description:
            'Fiecare solicitare primește număr, responsabil și status — poți urmări evoluția de la deschidere la închidere.',
          iconPath:
            'M16.5 6v.75m0 3v.75m0 3v.75M16.5 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25M3.75 18.75v-3.375c0-.621.504-1.125 1.125-1.125h9.75m-9.75 0V5.625c0-.621.504-1.125 1.125-1.125h5.25m-7.5 0h18',
        },
        {
          title: 'Remote support',
          description:
            'Asistență securizată la distanță pentru utilizatori și echipe distribuite, fără deplasări inutile.',
          iconPath:
            'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0015 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
        },
        {
          title: 'Intervenții on-site',
          description:
            'Deplasări la birou, depozit sau producție pentru montaj, înlocuiri hardware și remedieri care necesită prezență fizică.',
          iconPath:
            'M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M8.25 21h4.5m-4.5 0h-3m3.75-3v3.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
        },
      ]}
      steps={[
        {
          title: 'Analiză & inventar',
          description:
            'Evaluăm parcul IT, punctele critice și obiceiurile de lucru. Stabilim nivelul de serviciu și canalele de suport.',
        },
        {
          title: 'Implementare & onboarding',
          description:
            'Instalăm agenți de monitorizare, configurăm ticketingul și documentăm procedurile. Echipa ta știe cum ne contactează.',
        },
        {
          title: 'Operare & îmbunătățire',
          description:
            'Rulăm mentenanța periodică, urmărim incidentele și propunem optimizări — pentru stabilitate pe termen lung.',
        },
      ]}
    />
  </main>
  <Footer />
</Layout>
