---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceSections from '../../components/ServiceSections.astro';

const description =
  'Consultanță și audit IT: analiză infrastructură, recomandări personalizate, reducere costuri, vulnerabilități și optimizare performanță.';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Consultanță & Audit IT",
  "serviceType": "IT Consulting & Audit",
  "description": description,
  "url": "https://axait.ro/servicii/consultanta-audit",
  "provider": { "@id": "https://axait.ro/#business" },
  "areaServed": [
    { "@type": "City", "name": "București" },
    { "@type": "Country", "name": "România" }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://axait.ro/" },
    { "@type": "ListItem", "position": 2, "name": "Servicii", "item": "https://axait.ro/#servicii" },
    { "@type": "ListItem", "position": 3, "name": "Consultanță & Audit IT", "item": "https://axait.ro/servicii/consultanta-audit" }
  ]
};
---

<Layout title="Consultanță & Audit IT" description={description}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <Header variant="light" currentPage="/servicii/consultanta-audit" />
  <main>
    <ServiceSections
      accent="teal"
      eyebrow="Servicii AXA IT"
      title="Consultanță & Audit IT"
      heroImage="/img/servicii/consultanta-audit.jpg"
      heroDescription="Îți oferim o imagine obiectivă asupra infrastructurii: ce funcționează, ce te expune riscurilor și unde se pierd bani. Raportăm clar, cu priorități și estimări de efort — poți implementa singur sau cu noi, pas cu pas, fără soluții inutile."
      heroIconPath="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"
      features={[
        {
          title: 'Analiză infrastructură',
          description:
            'Rețea, servere, stații, cloud și licențe — hartă completă a dependențelor și a punctelor unice de eșec.',
          iconPath:
            'M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z',
        },
        {
          title: 'Propuneri personalizate',
          description:
            'Recomandări aliniate bugetului și maturității organizaționale — nu „best practices” copy-paste.',
          iconPath:
            'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
        },
        {
          title: 'Reducere costuri',
          description:
            'Identificăm licențe nefolosite, resurse supradimensionate și servicii duplicate — cu calcule simple ROI.',
          iconPath:
            'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
        },
        {
          title: 'Reducere vulnerabilități',
          description:
            'Review configurații, patch status, expunere la internet și practici de acces — cu listă de remediere.',
          iconPath:
            'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
        },
        {
          title: 'Optimizare performanță',
          description:
            'Gâtuiri de rețea, I/O disc sau aplicații — măsurători și tuning punctual, cu obiective măsurabile.',
          iconPath:
            'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
        },
      ]}
      steps={[
        {
          title: 'Analiză & interviuri',
          description:
            'Colectăm date tehnice și așteptările stakeholderilor. Definim scope-ul auditului și livrabilele.',
        },
        {
          title: 'Raport & workshop',
          description:
            'Prezentăm constatările, riscurile și roadmap-ul recomandat. Prioritizăm împreună quick wins vs. proiecte majore.',
        },
        {
          title: 'Implementare opțională',
          description:
            'Te sprijinim la execuție sau la verificarea furnizorilor terți — până când indicatorii îmbunătățirii sunt atinși.',
        },
      ]}
    />
  </main>
  <Footer />
</Layout>
