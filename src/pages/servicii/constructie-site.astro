---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceSections from '../../components/ServiceSections.astro';

const description =
  'Construim site-uri moderne, rapide și optimizate SEO — de la pagini de prezentare la magazine online — cu design personalizat și livrare în timp scurt.';
---

<Layout title="Construcție Site-uri Web" description={description}>
  <Header variant="light" currentPage="/servicii/constructie-site" />
  <main>
    <ServiceSections
      accent="emerald"
      eyebrow="Servicii AXA IT"
      title="Construcție Site-uri Web"
      heroImage="/img/servicii/constructie-site.jpg"
      heroDescription="Proiectăm și dezvoltăm site-uri web moderne — de la pagini de prezentare și landing pages, până la magazine online și platforme personalizate. Fiecare proiect pornește de la obiectivele afacerii tale și se livrează gata optimizat pentru Google și performanță pe mobil."
      heroIconPath="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
      features={[
        {
          title: 'Design personalizat',
          description:
            'Identitate vizuală adaptată brandului tău — paletă de culori, tipografie și layout unic, nu template generic.',
          iconPath:
            'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
        },
        {
          title: 'Rapid & optimizat SEO',
          description:
            'Timp de încărcare sub 2 secunde, structură corectă de headings, meta-date și sitemap — vizibilitate maximă în Google.',
          iconPath:
            'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
        },
        {
          title: 'Responsive pe orice dispozitiv',
          description:
            'Layout fluid testat pe telefon, tabletă și desktop — experiență perfectă pentru toți vizitatorii.',
          iconPath:
            'M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 8.25h3',
        },
        {
          title: 'CMS — editare simplă',
          description:
            'Poți actualiza conținut, adăuga articole sau schimba imagini direct din browser, fără cunoștințe tehnice.',
          iconPath:
            'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10',
        },
        {
          title: 'Hosting & întreținere',
          description:
            'Găzduire pe servere rapide, certificat SSL inclus, backup automat și actualizări de securitate lunare.',
          iconPath:
            'M21.75 17.25v-.228a4.5 4.5 0 00-.12-1.03l-2.268-9.64a3.375 3.375 0 00-3.285-2.602H7.923a3.375 3.375 0 00-3.285 2.602l-2.268 9.64a4.5 4.5 0 00-.12 1.03v.228m19.5 0a3 3 0 01-3 3H5.25a3 3 0 01-3-3m19.5 0a3 3 0 00-3-3H5.25a3 3 0 00-3 3m16.5 0h.008v.008h-.008v-.008zm-3 0h.008v.008h-.008v-.008z',
        },
        {
          title: 'Integrări & funcționalități',
          description:
            'Formulare de contact, Google Analytics, rezervări online, catalog de produse sau plăți — totul integrat și funcțional.',
          iconPath:
            'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
        },
      ]}
      steps={[
        {
          title: 'Discuție & briefing',
          description:
            'Înțelegem obiectivele afacerii, publicul țintă și funcționalitățile dorite. Îți propunem o soluție și un cost clar.',
        },
        {
          title: 'Design & dezvoltare',
          description:
            'Creăm wireframe-ul, îl aprobăm împreună, apoi construim site-ul și îl testăm pe toate dispozitivele.',
        },
        {
          title: 'Lansare & suport',
          description:
            'Publicăm site-ul, configurăm domeniul și Google Analytics. Rămânem alături cu suport și actualizări continue.',
        },
      ]}
      featuresHeading="Ce primești în proiect"
      processHeading="Cum lucrăm împreună"
    />
  </main>
  <Footer />
</Layout>
