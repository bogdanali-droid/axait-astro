---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceSections from '../../components/ServiceSections.astro';

const description =
  'Proiectare și implementare rețele cablate și Wi-Fi industrial — birouri, hale logistice, acoperire completă și documentație tehnică.';
---

<Layout title="Rețelistică & Wi-Fi Industrial" description={description}>
  <Header variant="light" currentPage="/servicii/retelistică-wifi" />
  <main>
    <ServiceSections
      accent="cyan"
      eyebrow="Servicii AXA IT"
      title="Rețelistică & Wi-Fi Industrial"
      heroDescription="Proiectăm LAN-uri structurate și wireless rezistent la medii dificile: hale, depozite, birouri open-space și zone cu roaming intens. Folosim echipamente enterprise (Ubiquiti, TP-Link Omada, Fortinet) și livrăm scheme, VLAN-uri și teste de acoperire documentate."
      heroIconPath="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"
      features={[
        {
          title: 'Rețele cablate structurate',
          description:
            'Cat6/Cat6A, rack-uri, patch panel-uri și etichetare logică. Separare VLAN pentru oaspeți, producție și administrare.',
          iconPath:
            'M8.25 3v18M15.75 3v18M3 8.25h18M3 15.75h18M4.5 3h15a1.5 1.5 0 011.5 1.5v15a1.5 1.5 0 01-1.5 1.5h-15a1.5 1.5 0 01-1.5-1.5v-15A1.5 1.5 0 014.5 3z',
        },
        {
          title: 'Wireless performant',
          description:
            'Design cu densitate AP, canal optim, band steering și roaming fără întreruperi pentru terminale mobile și scanere.',
          iconPath:
            'M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z',
        },
        {
          title: 'Hale logistice & producție',
          description:
            'Acoperire în zone înalte, rezistență la praf și temperaturi variate; integrare cu terminale WMS și vehicule.',
          iconPath:
            'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.107-8.177A2.25 2.25 0 0016.5 6.75h-9a2.25 2.25 0 00-2.227 2.568c.35.59.758 1.154 1.22 1.671',
        },
        {
          title: 'Birouri & sedii multi-etaj',
          description:
            'Backhaul între etaje, SSID-uri pentru vizitatori și politici de acces — fără congestie la ore de vârf.',
          iconPath:
            'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
        },
        {
          title: 'Documentație tehnică',
          description:
            'Scheme de adresare, port mapping, parole în vault și proceduri de recuperare — utile la audit sau extinderi.',
          iconPath:
            'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
        },
        {
          title: 'Acoperire completă',
          description:
            'Site survey, predicție și măsurători post-implementare — garantăm semnal acolo unde contează operațiunile tale.',
          iconPath:
            'M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z',
        },
      ]}
      steps={[
        {
          title: 'Analiză site',
          description:
            'Măsurători, interviuri cu echipele operaționale și definirea cerințelor de trafic, securitate și redundanță.',
        },
        {
          title: 'Proiectare & implementare',
          description:
            'Alegem echipamentele, cablăm, configurăm switch-uri, firewall și AP-uri. Testăm throughput și roaming.',
        },
        {
          title: 'Monitorizare & suport',
          description:
            'Actualizări firmware, health-check și intervenții la incidente — rețeaua rămâne predictibilă în timp.',
        },
      ]}
    />
  </main>
  <Footer />
</Layout>
