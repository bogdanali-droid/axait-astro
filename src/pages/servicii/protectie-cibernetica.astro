---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ServiceSections from '../../components/ServiceSections.astro';

const description =
  'Firewall, politici de acces, monitorizare rețea, antivirus centralizat și conformitate GDPR — reduci riscul de atacuri și incidente.';
---

<Layout title="Protecție Cibernetică & Securitate IT" description={description}>
  <Header variant="light" currentPage="/servicii/protectie-cibernetica" />
  <main>
    <ServiceSections
      accent="amber"
      eyebrow="Servicii AXA IT"
      title="Protecție Cibernetică & Securitate IT"
      heroDescription="Construim în straturi: perimetru, identități, endpoint-uri și date. Configurăm firewall-uri (Fortinet și altele), segmentăm rețeaua, aplicăm politici MFA și administrăm soluții EDR/antivirus centralizat. Te ajutăm să îndeplinești cerințe GDPR și bune practici NIS2 unde e cazul."
      heroIconPath="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
      features={[
        {
          title: 'Firewall & perimetru',
          description:
            'Reguli granulare, VPN securizat, IPS și logging către SIEM sau stocare păstrată conform retenției tale.',
          iconPath:
            'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
        },
        {
          title: 'Politici de acces',
          description:
            'Grupuri AD/Azure AD, privilegii minime, separare admin/user și revizii periodice ale drepturilor.',
          iconPath:
            'M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z',
        },
        {
          title: 'Monitorizare rețea',
          description:
            'Detectăm trafic anormal, tentative de lateral movement și exfiltrare — cu alerte și pași de remediere.',
          iconPath:
            'M5.636 5.636a9 9 0 1012.728 0M12 3v9',
        },
        {
          title: 'Antivirus centralizat',
          description:
            'Deployment politică, update-uri forțate, carantină și rapoarte de conformitate pe parcul de stații.',
          iconPath:
            'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
        },
        {
          title: 'GDPR & date sensibile',
          description:
            'Clasificare date, criptare la repaus și în tranzit, DLP unde e necesar și proceduri pentru breșe.',
          iconPath:
            'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m6.75 12h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876v9.576m0 0c-.35 0-.75.336-.75.75V21m-3.75 0h3.375',
        },
        {
          title: 'Prevenire atacuri',
          description:
            'Hardening servere, patch management, filtrare email și conștientizare utilizatori — reducem suprafața de atac.',
          iconPath:
            'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z',
        },
      ]}
      steps={[
        {
          title: 'Analiză & hardening',
          description:
            'Scanări de vulnerabilități, review configurații și plan de remediere prioritizat după impact și probabilitate.',
        },
        {
          title: 'Implementare controale',
          description:
            'Rulăm firewall, MFA, EDR și politici. Integrăm loguri și testăm scenarii de incident response.',
        },
        {
          title: 'Monitorizare & îmbunătățire',
          description:
            'Revizii trimestriale, patch-uri și adaptare la noi amenințări — securitatea nu e un proiect punctual.',
        },
      ]}
    />
  </main>
  <Footer />
</Layout>
